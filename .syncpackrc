{
  "indent": "  ",
  "semverGroups": [
    {
      "label": "Ignore internal @repo packages",
      "packages": ["**"],
      "dependencies": ["@repo/**"],
      "isIgnored": true
    }
  ],
  "versionGroups": [
    {
      "label": "Modules must not depend on other modules (use @repo/core or @repo/shared-*). Legacy violators carved out — track in docs/guidelines/monorepo.md and migrate gradually.",
      "packages": [
        "@repo/module-*",
        "!@repo/module-board",
        "!@repo/module-editor",
        "!@repo/module-newsletter"
      ],
      "dependencies": ["@repo/module-*"],
      "isBanned": true
    },
    {
      "label": "Use catalog: for external dependencies",
      "packages": ["**"],
      "dependencies": ["**"],
      "dependencyTypes": ["prod", "dev", "peer", "resolutions"],
      "preferVersion": "catalog:"
    }
  ],
  "sortAz": [
    "contributors",
    "dependencies",
    "devDependencies",
    "keywords",
    "peerDependencies",
    "resolutions",
    "scripts"
  ],
  "sortFirst": ["name", "description", "version", "author"]
}
