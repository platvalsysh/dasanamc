# ============================================================
# 외주 프로젝트 시작 시
#   1. 이 파일을 .env 로 복사 (`cp .env.example .env`)
#   2. 클라이언트별 Supabase 프로젝트를 새로 만들고 아래 값 채우기
#   3. ENABLED_MODULES 로 사용할 기능 모듈만 활성화
# 절대 이 파일에 실제 시크릿 값을 적지 말 것 (.env 만 사용, .env 는 gitignored)
# ============================================================

# ---- Supabase 자격증명 (https://supabase.com/dashboard 의 프로젝트 Settings → API)
VITE_SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
VITE_SUPABASE_ANON_KEY="[YOUR-ANON-KEY]"
SUPABASE_SERVICE_ROLE_KEY="[YOUR-SERVICE-ROLE-KEY]"

# ---- Postgres 연결
# ⚠️ direct 호스트(`db.[ref].supabase.co`)는 IPv6-only 라 IPv4 환경(개발 머신,
# Vercel 등 대부분)에서 DNS 해석 실패. pooler 호스트(`aws-1-[region].pooler.supabase.com`)
# 를 사용한다. 사용자명은 `postgres.[ref]` (구 `postgres` 가 아님).
# 정확한 host/region/user 는 Dashboard → Project Settings → Database
# → Connection string 에서 그대로 복사하는 것이 가장 안전.

# Transaction pooler (런타임 일반 쿼리용, port 6543)
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-1-[YOUR-REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Session pooler (마이그레이션용, port 5432, IPv4/IPv6 모두 지원)
DIRECT_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-1-[YOUR-REGION].pooler.supabase.com:5432/postgres"

# Prisma 쿼리 로그 (디버깅 시에만 1)
DATABASE_DEBUG=

# ---- SMS / 카카오 알림톡 테스트 모드
# SMS_TEST_MODE=1 → SolapiSmsProvider 대신 ConsoleSmsProvider 사용 (콘솔 출력만)
# SMS_TEST_NUMBER=01012345678 → 실제 발송이지만 이 번호로만 발송 (스테이징 안전장치)
SMS_TEST_MODE=
SMS_TEST_NUMBER=

# ---- 활성화할 기능 모듈 (콤마 구분)
# - 미설정 또는 빈 값 → 모든 모듈 활성 (개발 기본값)
# - 예: ENABLED_MODULES=board,file → 해당 모듈만 등록
# - core / auth / admin 은 화이트리스트와 무관하게 항상 활성
# - 사용 안 하는 모듈을 디렉토리 삭제 없이 빠르게 끄기 위한 외주 친화 옵션
# 활성 가능 모듈: board, editor, file, sms
ENABLED_MODULES=
