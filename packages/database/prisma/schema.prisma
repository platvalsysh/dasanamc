model comments {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  document_id      String             @db.Uuid
  content          String
  author_id        String?            @db.Uuid
  created_at       DateTime?          @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?          @default(now()) @db.Timestamptz(6)
  extra_vars       Json?              @default("{}")
  is_secret        Boolean?           @default(false)
  like_count       Int?               @default(0)
  parent_id        String?            @db.Uuid
  arrange          Int?               @default(0)
  depth            Int?               @default(0)
  blame_count      Int?               @default(0)
  file_count       Int?               @default(0)
  head             BigInt?            @default(autoincrement())
  comment_vote_log comment_vote_log[]
  users            users?             @relation(fields: [author_id], references: [id])
  documents        documents          @relation(fields: [document_id], references: [id], onDelete: Cascade)
  comments         comments?          @relation("commentsTocomments", fields: [parent_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_comments_parent")
  other_comments   comments[]         @relation("commentsTocomments")

  @@index([author_id])
  @@index([document_id])
  @@index([document_id, head, arrange], map: "idx_comments_hierarchy")
  @@schema("modules")
}

model document_categories {
  id                        String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  seq                       Int
  module_id                 String                @db.Uuid
  parent_id                 String?               @db.Uuid
  name                      String                @db.VarChar(255)
  path                      String?               @db.VarChar(1000)
  depth                     Int                   @default(0)
  description               String?               @db.VarChar(255)
  list_order                Int                   @default(0)
  document_count            Int                   @default(0)
  extra_vars                Json?                 @default("{}")
  created_at                DateTime?             @default(now()) @db.Timestamptz(6)
  updated_at                DateTime?             @default(now()) @db.Timestamptz(6)
  modules                   modules               @relation(fields: [module_id], references: [id], onDelete: Cascade)
  document_categories       document_categories?  @relation("document_categoriesTodocument_categories", fields: [parent_id], references: [id])
  other_document_categories document_categories[] @relation("document_categoriesTodocument_categories")
  documents                 documents[]

  @@index([list_order])
  @@index([module_id])
  @@index([parent_id])
  @@index([path])
  @@schema("modules")
}

