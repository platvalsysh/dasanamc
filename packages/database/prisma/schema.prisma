  comments   comments  @relation(fields: [comment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([comment_id, user_id, vote_type], map: "idx_cmt_vote_member")
  @@index([user_id, created_at(sort: Desc)], map: "idx_cmt_vote_user_time")
