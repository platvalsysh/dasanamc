model documents {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  module_id             String                  @db.Uuid
  title                 String                  @db.VarChar(255)
  content               String?
  author_id             String?                 @db.Uuid
  view_count            Int                     @default(0)
  created_at            DateTime?               @default(now()) @db.Timestamptz(6)
  updated_at            DateTime?               @default(now()) @db.Timestamptz(6)
  thumbnail             String?                 @db.Uuid
  extra_vars            Json?                   @default("{}")
  is_notice             Boolean?                @default(false)
  is_secret             Boolean?                @default(false)
  comment_count         Int?                    @default(0)
  like_count            Int?                    @default(0)
  status                String?                 @default("PUBLIC") @db.VarChar(20)
  comment_status        String?                 @default("ALLOW") @db.VarChar(20)
  blame_count           Int?                    @default(0)
  file_count            Int?                    @default(0)
  category_id           String?                 @db.Uuid
  comments              comments[]
  document_ip_view_log  document_ip_view_log[]
  document_read_history document_read_history[]
  document_vote_log     document_vote_log[]
  users                 users?                  @relation(fields: [author_id], references: [id])
  document_categories   document_categories?    @relation(fields: [category_id], references: [id])
  modules               modules                 @relation(fields: [module_id], references: [id], onDelete: Cascade)
  files                 files?                  @relation(fields: [thumbnail], references: [id])

  @@index([author_id])
  @@index([category_id])
  @@index([module_id])
  @@index([thumbnail])
  @@index([module_id, like_count(sort: Desc)], map: "idx_documents_like_ranking")
  @@index([module_id, is_notice(sort: Desc), created_at(sort: Desc)], map: "idx_documents_listing")
  @@index([module_id, view_count(sort: Desc)], map: "idx_documents_view_ranking")
  @@schema("modules")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model files {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  module         String      @db.VarChar(255)
  module_id      String?     @db.Uuid
  target_id      String?     @db.Uuid
  original_name  String      @db.VarChar(255)
  file_size      BigInt
  mime_type      String?     @db.VarChar(255)
  extension      String?     @db.VarChar(255)
  storage_type   String      @db.VarChar(10)
  local_path     String?
  s3_bucket      String?     @db.VarChar(100)
  s3_key         String?
  s3_region      String?     @db.VarChar(50)
  status         String      @default("P") @db.Char(1)
  created_at     DateTime?   @default(now()) @db.Timestamptz(6)
  uploaded_at    DateTime?   @db.Timestamptz(6)
  uploaded_by    String?     @db.Uuid
  download_count BigInt      @default(0)
  is_publish     Boolean     @default(false)
  variants       Json?
  documents      documents[]
  modules        modules?    @relation(fields: [module_id], references: [id])
  users          users?      @relation(fields: [uploaded_by], references: [id])

  @@index([created_at(sort: Desc)])
  @@index([is_publish])
  @@index([module_id])
  @@index([module])
  @@index([module, target_id], map: "files_module_target_idx")
  @@index([status])
  @@index([target_id])
  @@index([uploaded_by])
  @@schema("modules")
}

